{
  "name": "scholr",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:lan": "expo start --lan",
    "start:lan:clear": "expo start --lan --clear",
    "start:tunnel": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-expo-tunnel.ps1 -TunnelOnly",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "create:admin": "node ./scripts/createAdmin.js",
    "delete:user": "node ./scripts/deleteUser.js",
    "delete:process": "node ./scripts/processDeletionQueue.js",
    "functions:install": "npm --prefix ./functions install --legacy-peer-deps",
    "functions:deploy": "firebase deploy --only functions",
    "tunnel": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-expo-tunnel.ps1 -TunnelOnly",
    "tunnel:clear": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-expo-tunnel.ps1 -TunnelOnly -Clear",
    "start:auto": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-expo-tunnel.ps1"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "expo": "~54.0.0",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.10.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "private": true,
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "expo-module-scripts": "^55.0.2",
    "firebase-admin": "^13.7.0",
    "typescript": "^5.9.3"
  }
}
